# API Configuration
API_URL=http://localhost:3000/v0/headless/inspect
API_KEY=your_api_key_here
WORKSPACE_ID=your_workspace_id_here

# Form Data
PRODUCT_NAME=little_mixer
SESSION_NAME=Grace-Test005
ARTICLE_NAME=grade_match
NEXT_ARTICLE=true
IMAGE_FIELD_NAME=image_file

# Source Configuration: 'baumer', 'rtsp', or 'webcam'
SOURCE_TYPE=baumer

# RTSP Configuration (required if SOURCE_TYPE=rtsp)
RTSP_URL=rtsp://username:password@ip_address:port/path

# Webcam Configuration (required if SOURCE_TYPE=webcam)
# WEBCAM_ID can be:
#   - An integer index: 0, 1, 2 ...  (run list_webcams() to discover)
#   - A device name substring: "USB Camera", "Logitech", "Integrated"
WEBCAM_ID=0

# Storage Configuration
IMAGES_SAVE_PATH=./images

# Modbus Button Trigger (set MODBUS_TRIGGER=true to enable)
MODBUS_TRIGGER=true
MODBUS_HOST=192.168.7.120
MODBUS_PORT=502
MODBUS_ADDRESS=0
MODBUS_UNIT=1
MODBUS_USE_COIL=true
MODBUS_POLL_INTERVAL=0.1
